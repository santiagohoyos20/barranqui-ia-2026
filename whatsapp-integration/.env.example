# ============================================
# CONFIGURACIÓN DE WHATSAPP
# ============================================

# ID del número telefónico de WhatsApp
# Puedes encontrarlo en: Meta Dashboard → Settings → Phone Numbers
WHATSAPP_PHONE_NUMBER_ID=123456789

# ID de la cuenta de negocio de WhatsApp
# Puedes encontrarlo en: Meta Dashboard → Settings → Business
WHATSAPP_BUSINESS_ACCOUNT_ID=987654321

# Token de acceso de WhatsApp
# Este token es crítico - mantén este valor secreto
# Generado en: Meta Dashboard → Settings → System User Access Tokens
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token que usarás para verificar webhooks
# Puedes establecer cualquier valor que prefieras
# Este debe coincidir con el valor en Meta Dashboard
WHATSAPP_WEBHOOK_TOKEN=tu_webhook_token_secreto_muy_seguro

# ============================================
# CONFIGURACIÓN DEL AGENTE IA
# ============================================

# URL del endpoint del Agente IA
# Ejemplo: http://localhost:3001 (local)
# o https://tu-agente.com (remoto)
AGENT_API_URL=http://localhost:3001

# Clave API del agente (si es requerida)
# Déjala vacía si el agente no requiere autenticación
AGENT_API_KEY=tu_api_key_del_agente

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Puerto donde escuchará el servidor
PORT=3000

# Ambiente de ejecución
# Valores: development, production
NODE_ENV=development

# Nivel de logging
# Valores: error, warn, info, http, debug, silly
LOG_LEVEL=info
