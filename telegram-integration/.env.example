# ============================================
# CONFIGURACIÓN DE TELEGRAM
# ============================================

# Token del bot generado por @BotFather en Telegram
# Pasos:
#   1. Abre Telegram y busca @BotFather
#   2. Envía /newbot y sigue los pasos
#   3. Copia el token y pégalo aquí
# Formato: 1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Token compartido (secret_token) que Telegram enviará en cada webhook
# en la cabecera X-Telegram-Bot-Api-Secret-Token.
# Acepta 1-256 caracteres: A-Z, a-z, 0-9, '_' y '-'.
# Genera un valor aleatorio y mantenlo en secreto.
TELEGRAM_WEBHOOK_SECRET_TOKEN=cambia_este_valor_por_uno_secreto

# URL pública donde Telegram enviará los updates (HTTPS obligatorio).
# Si la dejas vacía, deberás registrar el webhook manualmente con setWebhook.
# Ejemplo: https://miapp.ngrok.io  o  https://miapp.up.railway.app
TELEGRAM_WEBHOOK_URL=

# Path interno del webhook (debe coincidir con la ruta expuesta por Express).
# Por defecto: /webhook/telegram
TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# ============================================
# CONFIGURACIÓN DEL AGENTE IA
# ============================================

# URL del endpoint del Agente IA
# Ejemplo: http://localhost:3001 (local)
# o https://tu-agente.com (remoto)
AGENT_API_URL=http://localhost:3001

# Clave API del agente (si es requerida)
# Déjala vacía si el agente no requiere autenticación
AGENT_API_KEY=tu_api_key_del_agente

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Puerto donde escuchará el servidor
PORT=3000

# Ambiente de ejecución
# Valores: development, production
NODE_ENV=development

# Nivel de logging
# Valores: error, warn, info, http, debug, silly
LOG_LEVEL=info
