# URL del backend (endpoint de chat)
# Debe ser accesible desde el navegador del usuario.
VITE_API_URL=http://localhost:3000/agent/chat

# Dashboard comercial
VITE_FINANCE_API_URL=http://localhost:3000/api/finance

# Supabase REST API para el dashboard comercial
VITE_SUPABASE_URL=https://svorevemywtrfqawmcnv.supabase.co/rest/v1
VITE_SUPABASE_ANON_KEY=replace_with_your_supabase_anon_key
